<view class="login">
  <view class="login-container">
    <text class="title">欢迎登录</text>
    <view class="role-selection">
      <text class="subtitle">选择角色</text>
      <view class="role-buttons">
        <view 
          class="role-btn" 
          class="{{ selectedRole === 'customer' ? 'active' : '' }}"
          bindtap="selectRole"
          data-role="customer"
        >
          <text class="icon">👤</text>
          <text class="text">顾客</text>
        </view>
        <view 
          class="role-btn" 
          class="{{ selectedRole === 'merchant' ? 'active' : '' }}"
          bindtap="selectRole"
          data-role="merchant"
        >
          <text class="icon">🏪</text>
          <text class="text">商家</text>
        </view>
      </view>
    </view>
    <button class="login-btn" bindtap="login">登录</button>
  </view>
</view>
