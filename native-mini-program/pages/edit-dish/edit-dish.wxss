.add-dish {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.page-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  text-align: center;
  color: #333;
}

.form-item {
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input {
  width: 100%;
  font-size: 28rpx;
  padding: 15rpx;
  border: 1rpx solid #ddd;
  border-radius: 5rpx;
  background-color: #f9f9f9;
}

.textarea {
  width: 100%;
  font-size: 28rpx;
  padding: 15rpx;
  border: 1rpx solid #ddd;
  border-radius: 5rpx;
  background-color: #f9f9f9;
  min-height: 150rpx;
  resize: none;
}

.image-upload {
  display: flex;
  align-items: center;
}

.dish-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
}

.upload-btn {
  padding: 0 30rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 26rpx;
  background-color: #1aad19;
  color: #fff;
  border-radius: 5rpx;
}

.picker {
  width: 100%;
  font-size: 28rpx;
  padding: 15rpx;
  border: 1rpx solid #ddd;
  border-radius: 5rpx;
  background-color: #f9f9f9;
}

.picker-text {
  color: #333;
}

.button-group {
  display: flex;
  justify-content: space-between;
  margin-top: 40rpx;
}

.cancel-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  background-color: #fff;
  color: #666;
  border: 1rpx solid #ddd;
  border-radius: 5rpx;
  margin-right: 20rpx;
}

.submit-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  background-color: #1aad19;
  color: #fff;
  border-radius: 5rpx;
}

/* 适配不同屏幕尺寸 */
@media (max-width: 375px) {
  .add-dish {
    padding: 15rpx;
  }
  
  .page-title {
    font-size: 28rpx;
  }
  
  .form-item {
    padding: 15rpx;
  }
  
  .label {
    font-size: 26rpx;
  }
  
  .input,
  .textarea,
  .picker {
    font-size: 26rpx;
    padding: 12rpx;
  }
  
  .dish-image {
    width: 160rpx;
    height: 160rpx;
  }
  
  .upload-btn {
    height: 60rpx;
    line-height: 60rpx;
    font-size: 24rpx;
  }
  
  .cancel-btn,
  .submit-btn {
    height: 70rpx;
    line-height: 70rpx;
    font-size: 26rpx;
  }
}