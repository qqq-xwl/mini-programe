<view class="mine">
  <view class="user-info">
    <view class="avatar">
      <text class="avatar-icon">{{ userRole === 'customer' ? '👤' : '🏪' }}</text>
    </view>
    <view class="user-details">
      <text class="user-name">{{ userRole === 'customer' ? '顾客' : '商家' }}</text>
      <text class="user-role">{{ userRole === 'customer' ? '普通用户' : '商家管理' }}</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="viewOrders">
      <text class="menu-icon">📋</text>
      <text class="menu-text">我的订单</text>
      <text class="menu-arrow">→</text>
    </view>

    <view wx:if="{{ userRole === 'merchant' }}" class="menu-item" bindtap="goToMerchant">
      <text class="menu-icon">🛠️</text>
      <text class="menu-text">商家管理</text>
      <text class="menu-arrow">→</text>
    </view>

    <view class="menu-item" bindtap="logout">
      <text class="menu-icon">🚪</text>
      <text class="menu-text">退出登录</text>
      <text class="menu-arrow">→</text>
    </view>
  </view>

  <view class="order-list">
    <h2>最近订单</h2>
    <view wx:if="{{ orders.length === 0 }}" class="no-orders">
      <text>暂无订单</text>
    </view>
    <view wx:for="{{ orders }}" wx:key="{{ item.id }}" class="order-item">
      <view class="order-header">
        <text class="order-id">订单号: {{ item.id }}</text>
        <text class="order-status">{{ item.status }}</text>
      </view>
      <view class="order-content">
        <text class="order-amount">金额: ¥{{ item.total_price.toFixed(2) }}</text>
        <text class="order-time">{{ item.created_at }}</text>
      </view>
    </view>
  </view>
</view>